package collections.HashSet;

import java.util.ArrayList;
import java.util.HashSet;
import java.util.List;
import java.util.Set;

public class C20_RemoveHashSetElements 
{
	public static void main(String[] args) 
	{
		System.out.println("--------------------------------------------------------------------------------");
		System.out.println("1. Creating a HashSet and adding elements");
		Set<Integer> numbers = new HashSet<>();
		numbers.add(2);
		numbers.add(3);
		numbers.add(4);
		numbers.add(5);
		numbers.add(6);
		numbers.add(7);
		numbers.add(8);
		numbers.add(9);
		numbers.add(10);
		System.out.println("OUTPUT:"+numbers);
		System.out.println("--------------------------------------------------------------------------------");
		System.out.println("remove() -> Remove a specific element from the HashSet.");
		numbers.remove(2);
		System.out.println("OUTPUT:"+numbers);
		System.out.println("--------------------------------------------------------------------------------");
		System.out.println("removeAll() -> Remove all elements from the specified collection.");
		List<Integer> ps = new ArrayList<>();
		ps.add(4);
		ps.add(9);
		numbers.removeAll(ps);
		System.out.println("OUTPUT:"+numbers);
		System.out.println("--------------------------------------------------------------------------------");
		System.out.println("removeIf() -> Remove all elements that satisfy a given predicate");
		numbers.removeIf((p) -> {return p%2 == 0;});
		System.out.println("OUTPUT:"+numbers);
		System.out.println("--------------------------------------------------------------------------------");
		System.out.println("clear() -> Clear all elements from the HashSet.");
		numbers.clear();
		
		
		
		
	}

}
