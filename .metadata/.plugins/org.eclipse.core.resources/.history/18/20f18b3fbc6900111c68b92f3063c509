package collections;

import java.util.ArrayList;
import java.util.List;

public class C03_AccessingElementsFromArrayList 
{
	public static void main(String[] args) 
	{
		System.out.println("-------------------------------------------------------------------------------------------------------");
		System.out.println("Sceanrio 1: How to check if an ArrayList is empty using `isEmpty()` method");
		List<String> companies = new ArrayList<>();
		System.out.println("Is the Companies list empty: "+companies.isEmpty());
		System.out.println("-------------------------------------------------------------------------------------------------------");
		System.out.println("Sceanrio 2: How to find the size of an ArrayList using the `size()` method");
		companies.add("Google");
		companies.add("Apple");
		companies.add("Microsoft");
		companies.add("Amazon");
		System.out.println("Companies List Size: "+companies.size());
		System.out.println("-------------------------------------------------------------------------------------------------------");
		
	}

}
