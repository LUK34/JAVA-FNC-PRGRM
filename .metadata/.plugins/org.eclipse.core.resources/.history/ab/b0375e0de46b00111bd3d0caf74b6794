package collections.ArrayList;

import java.util.ArrayList;
import java.util.List;

public class C05_IteratingOverArrayList 
{
	public static void main(String[] args) 
	{
		System.out.println("-------------------------------------------------------------------------------------------------------");	
		List<String> pl = new ArrayList<>();
		pl.add("C"); //0
		pl.add("C++"); //1
		pl.add("Java"); //2
		pl.add("Kotlin"); //3
		pl.add("Python"); //4
		pl.add("Perl"); //5
		pl.add("Ruby"); //6
		System.out.println("Scenario 1: Using Simple FOR LOOP");
		
	}

}
