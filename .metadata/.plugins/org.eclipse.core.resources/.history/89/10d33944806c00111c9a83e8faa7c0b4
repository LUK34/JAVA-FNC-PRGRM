package collections.HashSet;

import java.util.ArrayList;
import java.util.HashSet;
import java.util.List;

public class C18_CreateHashSetFromAnotherCllcts 
{
	public static void main(String[] args) 
	{
		System.out.println("----------------------------------------------------------------------------");
		List<Integer> l1 = new ArrayList<>();
		l1.add(1);
		l1.add(2);
		l1.add(3);
		l1.add(4);
		l1.add(5);
		
		List<Integer> l2 = new ArrayList<>();
		l2.add(6);
		l2.add(7);
		l2.add(8);
		l2.add(9);
		l2.add(20);

		System.out.println("----------------------------------------------------------------------------");
		System.out.println("1. Creating HashSet from another collection.");
		HashSet<Integer> h1 = new HashSet<>(l1);
		System.out.println(h1);
		System.out.println("----------------------------------------------------------------------------");
		System.out.println("2. Add all elements from another collection to the HashSet using the addAll() method.");
		h1.addAll(l2);
		
	}

}
